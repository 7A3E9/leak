StatusLabel.Font = Enum.Font.Gotham; StatusLabel.TextSize = 13; StatusLabel.TextXAlignment = 0; StatusLabel.TextTransparency = 1

-------------------------------------------------------------------------------
-- [ ANIMATION HANDLERS ]
-------------------------------------------------------------------------------

local function Fade(objects, goal)
    for obj, props in pairs(objects) do
        TweenService:Create(obj, TWEEN_INFO, props):Play()
    end
end

local function FadeInKey()
    Fade({
        [KeyFrame] = {BackgroundTransparency = 0},
        [KeyStroke] = {Transparency = 0},
        [KeyTitle] = {TextTransparency = 0},
        [KeySub] = {TextTransparency = 0},
        [TextBox] = {BackgroundTransparency = 0, TextTransparency = 0},
        [NoteText] = {TextTransparency = 0}
    })
end

local function FadeOutKey()
    Fade({
        [KeyFrame] = {BackgroundTransparency = 1},
        [KeyStroke] = {Transparency = 1},
        [KeyTitle] = {TextTransparency = 1},
        [KeySub] = {TextTransparency = 1},
        [TextBox] = {BackgroundTransparency = 1, TextTransparency = 1},
        [NoteText] = {TextTransparency = 1}
    })
    task.wait(0.5)
    KeyFrame.Visible = false
end

local function FadeInMain()
    MainFrame.Visible = true
    Fade({
        [MainFrame] = {BackgroundTransparency = 0},
        [MainStroke] = {Transparency = 0},
        [Title] = {TextTransparency = 0},
        [TopDivider] = {BackgroundTransparency = 0},
        [Btn1] = {BackgroundTransparency = 0}, [T1] = {TextTransparency = 0}, [S1] = {Transparency = 0}, [AF1] = {BackgroundTransparency = 0}, [AL1] = {TextTransparency = 0},
        [Btn2] = {BackgroundTransparency = 0}, [T2] = {TextTransparency = 0}, [S2] = {Transparency = 0}, [AF2] = {BackgroundTransparency = 0}, [AL2] = {TextTransparency = 0},
        [StatusContainer] = {BackgroundTransparency = 0}, [StatusStroke] = {Transparency = 0}, [StatusLabel] = {TextTransparency = 0}
    })
end

-------------------------------------------------------------------------------
-- [ CORE LOGIC ]
-------------------------------------------------------------------------------

-- Key Check Logic
TextBox:GetPropertyChangedSignal("Text"):Connect(function()
    if TextBox.Text == CORRECT_KEY then
        TextBox.TextEditable = false
        TextBox.TextColor3 = Color3.fromRGB(100, 255, 100)
        task.wait(0.3)
        FadeOutKey()
        task.wait(0.1)
        FadeInMain()
    end
end)

-- Draggable Logic Helper
local function makeDraggable(frame, handle)
    local dragging, dragInput, dragStart, startPos
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true; dragStart = input.Position; startPos = frame.Position
            input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

makeDraggable(KeyFrame, KeyFrame)
makeDraggable(MainFrame, TopBar)

-- [ BUTTON FUNCTIONALITIES ]
local function updateStatus(text, color)
    StatusLabel.Text = text
    TweenService:Create(StatusLabel, TweenInfo.new(0.3), {TextColor3 = color or Colors.TextGray}):Play()
end

Btn1.MouseButton1Click:Connect(function()
    updateStatus("Saving Script...", Color3.fromRGB(255, 200, 100))
    if not saveinstance then updateStatus("Error: Unsupported Executor", Color3.fromRGB(255, 80, 80)) return end
    local s, e = pcall(function() saveinstance() end)
    if s then updateStatus("Success! Check workspace.", Color3.fromRGB(100, 255, 100)) else updateStatus("Error: "..tostring(e):sub(1,20), Color3.fromRGB(255, 80, 80)) end
end)

Btn2.MouseButton1Click:Connect(function()
    updateStatus("Saving Map + Terrain...", Color3.fromRGB(255, 200, 100))
    local s, e = pcall(function()
        local synsaveinstance = loadstring(game:HttpGet("https://raw.githubusercontent.com/verysigmapro/UniversalSynSaveInstance-With-Save-Terrain/refs/heads/main/saveinstance_rewrite.luau", true), "saveinstance")();
        synsaveinstance({usekonstantdecompiler = false});
    end)
    if s then updateStatus("Success! Map saved.", Color3.fromRGB(100, 255, 100)) else updateStatus("Error: "..tostring(e):sub(1,20), Color3.fromRGB(255, 80, 80)) end
end)

-- Start Application
FadeInKey()
