-- [ MAP DUMPER WITH KEY SYSTEM UI ]
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")
local CoreGui = game:GetService("CoreGui")

local LP = Players.LocalPlayer
local CorrectKey = "leak888"

-- Cleanup Old UI
local oldGui = CoreGui:FindFirstChild("MapDumperHub")
if oldGui then oldGui:Destroy() end

local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "MapDumperHub"
ScreenGui.Parent = CoreGui
ScreenGui.ResetOnSpawn = false
ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

local Colors = {
    Background = Color3.fromRGB(25, 25, 25),
    ElementBg = Color3.fromRGB(35, 35, 35),
    Hover = Color3.fromRGB(45, 45, 45),
    Stroke = Color3.fromRGB(55, 55, 55),
    TextWhite = Color3.fromRGB(240, 240, 240),
    TextGray = Color3.fromRGB(150, 150, 150),
    Accent = Color3.fromRGB(100, 170, 255)
}

-- ==========================================
-- [ PART 1: MAIN GUI FUNCTION ]
-- ==========================================
local function loadMainGUI()
    local MainFrame = Instance.new("Frame")
    MainFrame.Name = "MainFrame"
    MainFrame.Parent = ScreenGui
    MainFrame.Size = UDim2.new(0, 420, 0, 260)
    MainFrame.Position = UDim2.new(0.5, -210, 0.5, -130)
    MainFrame.BackgroundColor3 = Colors.Background
    MainFrame.BorderSizePixel = 0
    MainFrame.ClipsDescendants = true
    
    -- Animation เด้งขึ้นมา
    MainFrame.GroupTransparency = 1
    MainFrame.Position = UDim2.new(0.5, -210, 0.5, -120)
    TweenService:Create(MainFrame, TweenInfo.new(0.5, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
        GroupTransparency = 0,
        Position = UDim2.new(0.5, -210, 0.5, -130)
    }):Play()

    Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0, 8)
    local MainStroke = Instance.new("UIStroke", MainFrame)
    MainStroke.Color = Colors.Stroke
    MainStroke.Thickness = 1.2
    MainStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

    local TopBar = Instance.new("Frame", MainFrame)
    TopBar.Size = UDim2.new(1, 0, 0, 40)
    TopBar.BackgroundTransparency = 1

    local Title = Instance.new("TextLabel", TopBar)
    Title.Size = UDim2.new(1, -20, 1, 0)
    Title.Position = UDim2.new(0, 15, 0, 0)
    Title.BackgroundTransparency = 1
    Title.Text = "🔥 Map Dumper Script | Made by 7A3E9"
    Title.TextColor3 = Colors.TextWhite
    Title.Font = Enum.Font.GothamBold
    Title.TextSize = 14
    Title.TextXAlignment = Enum.TextXAlignment.Left

    local TopDivider = Instance.new("Frame", MainFrame)
    TopDivider.Size = UDim2.new(1, 0, 0, 1)
    TopDivider.Position = UDim2.new(0, 0, 0, 40)
    TopDivider.BackgroundColor3 = Colors.Stroke
    TopDivider.BorderSizePixel = 0

    local Content = Instance.new("Frame", MainFrame)
    Content.Size = UDim2.new(1, 0, 1, -41)
    Content.Position = UDim2.new(0, 0, 0, 41)
    Content.BackgroundTransparency = 1

    local UIListLayout = Instance.new("UIListLayout", Content)
    UIListLayout.SortOrder = Enum.SortOrder.LayoutOrder
    UIListLayout.Padding = UDim.new(0, 8)

    local UIPadding = Instance.new("UIPadding", Content)
    UIPadding.PaddingTop = UDim.new(0, 12)
    UIPadding.PaddingLeft = UDim.new(0, 15)
    UIPadding.PaddingRight = UDim.new(0, 15)

    local function createSectionText(text)
        local Label = Instance.new("TextLabel", Content)
        Label.Size = UDim2.new(1, 0, 0, 18)
        Label.BackgroundTransparency = 1
        Label.Text = text
        Label.TextColor3 = Colors.TextGray
        Label.Font = Enum.Font.GothamMedium
        Label.TextSize = 12
        Label.TextXAlignment = Enum.TextXAlignment.Left
    end

    local function createRowButton(text, actionText)
        local Btn = Instance.new("TextButton", Content)
        Btn.Size = UDim2.new(1, 0, 0, 38)
        Btn.BackgroundColor3 = Colors.ElementBg
        Btn.AutoButtonColor = false
        Btn.Text = ""
        Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 6)
        local Stroke = Instance.new("UIStroke", Btn)
        Stroke.Color = Colors.Stroke
        Stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
        
        local MainText = Instance.new("TextLabel", Btn)
        MainText.Size = UDim2.new(1, -90, 1, 0)
        MainText.Position = UDim2.new(0, 12, 0, 0)
        MainText.BackgroundTransparency = 1
        MainText.Text = text
        MainText.TextColor3 = Colors.TextWhite
        MainText.Font = Enum.Font.GothamMedium
        MainText.TextSize = 14
        MainText.TextXAlignment = Enum.TextXAlignment.Left
        
        local ActionFrame = Instance.new("Frame", Btn)
        ActionFrame.Size = UDim2.new(0, 70, 0, 24)
        ActionFrame.Position = UDim2.new(1, -80, 0.5, -12)
        ActionFrame.BackgroundColor3 = Colors.Background
        Instance.new("UICorner", ActionFrame).CornerRadius = UDim.new(0, 4)
        Instance.new("UIStroke", ActionFrame).Color = Colors.Stroke
        
        local ActionLabel = Instance.new("TextLabel", ActionFrame)
        ActionLabel.Size = UDim2.new(1, 0, 1, 0)
        ActionLabel.BackgroundTransparency = 1
        ActionLabel.Text = actionText
        ActionLabel.TextColor3 = Colors.TextGray
        ActionLabel.Font = Enum.Font.Gotham
        ActionLabel.TextSize = 12
        
        Btn.MouseEnter:Connect(function()
            TweenService:Create(Btn, TweenInfo.new(0.2), {BackgroundColor3 = Colors.Hover}):Play()
            TweenService:Create(ActionLabel, TweenInfo.new(0.2), {TextColor3 = Colors.TextWhite}):Play()
        end)
        Btn.MouseLeave:Connect(function()
            TweenService:Create(Btn, TweenInfo.new(0.2), {BackgroundColor3 = Colors.ElementBg}):Play()
            TweenService:Create(ActionLabel, TweenInfo.new(0.2), {TextColor3 = Colors.TextGray}):Play()
        end)
        return Btn
    end

    createSectionText("Main Functions")
    local Btn1 = createRowButton("💾  Leak Standard Script", "Save")
    local Btn2 = createRowButton("🗺️  Leak Map (With Terrain)", "Load")

    createSectionText("Status")
    local StatusContainer = Instance.new("Frame", Content)
    StatusContainer.Size = UDim2.new(1, 0, 0, 30)
    StatusContainer.BackgroundColor3 = Colors.Background
    Instance.new("UICorner", StatusContainer).CornerRadius = UDim.new(0, 6)
    Instance.new("UIStroke", StatusContainer).Color = Colors.Stroke

    local StatusLabel = Instance.new("TextLabel", StatusContainer)
    StatusLabel.Size = UDim2.new(1, -20, 1, 0)
    StatusLabel.Position = UDim2.new(0, 10, 0, 0)
    StatusLabel.BackgroundTransparency = 1
    StatusLabel.Text = "Idle..."
    StatusLabel.TextColor3 = Colors.TextGray
    StatusLabel.Font = Enum.Font.Gotham
    StatusLabel.TextSize = 13
    StatusLabel.TextXAlignment = Enum.TextXAlignment.Left

    -- Logic ปุ่ม Main GUI
    local function updateStatus(text, color)
        StatusLabel.Text = text
        TweenService:Create(StatusLabel, TweenInfo.new(0.3), {TextColor3 = color or Colors.TextGray}):Play()
    end

    Btn1.MouseButton1Click:Connect(function()
        updateStatus("Saving Script...", Color3.fromRGB(255, 200, 100))
        task.wait(0.1)
        if not saveinstance then updateStatus("Error: Executor unsupported", Color3.fromRGB(255, 80, 80)) return end
        local s, e = pcall(function() saveinstance() end)
        if s then updateStatus("Success! Check workspace folder.", Color3.fromRGB(100, 255, 100))
        else updateStatus("Error: " .. tostring(e):sub(1, 30), Color3.fromRGB(255, 80, 80)) end
    end)

    Btn2.MouseButton1Click:Connect(function()
        updateStatus("Downloading Terrain Saver...", Color3.fromRGB(255, 200, 100))
        task.wait(0.1)
        local s, e = pcall(function()
            local synsaveinstance = loadstring(game:HttpGet("https://raw.githubusercontent.com/verysigmapro/UniversalSynSaveInstance-With-Save-Terrain/refs/heads/main/saveinstance_rewrite.luau", true), "saveinstance")()
            synsaveinstance({usekonstantdecompiler = false})
        end)
        if s then updateStatus("Success! Map saved.", Color3.fromRGB(100, 255, 100))
        else updateStatus("Error: " .. tostring(e):sub(1, 30), Color3.fromRGB(255, 80, 80)) end
    end)

    -- ลากหน้าต่างหลัก
    local dragging, dragInput, dragStart, startPos
    TopBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; dragStart = input.Position; startPos = MainFrame.Position
            input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
        end
    end)
    TopBar.InputChanged:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

-- ==========================================
-- [ PART 2: KEY SYSTEM UI ]
-- ==========================================
local KeyGroup = Instance.new("CanvasGroup")
KeyGroup.Name = "KeySystem"
KeyGroup.Parent = ScreenGui
KeyGroup.Size = UDim2.new(0, 480, 0, 160)
KeyGroup.Position = UDim2.new(0.5, -240, 0.5, -80)
KeyGroup.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
KeyGroup.BorderSizePixel = 0
KeyGroup.GroupTransparency = 1 -- เริ่มต้นแบบซ่อนไว้
Instance.new("UICorner", KeyGroup).CornerRadius = UDim.new(0, 8)

-- Header
local KeyTitle = Instance.new("TextLabel", KeyGroup)
KeyTitle.Size = UDim2.new(1, -40, 0, 25)
KeyTitle.Position = UDim2.new(0, 20, 0, 15)
KeyTitle.BackgroundTransparency = 1
KeyTitle.Text = "Key | Map Dumper Hub"
KeyTitle.TextColor3 = Colors.TextWhite
KeyTitle.Font = Enum.Font.GothamBold
KeyTitle.TextSize = 16
KeyTitle.TextXAlignment = Enum.TextXAlignment.Left

local KeySubTitle = Instance.new("TextLabel", KeyGroup)
KeySubTitle.Size = UDim2.new(1, -40, 0, 20)
KeySubTitle.Position = UDim2.new(0, 20, 0, 35)
KeySubTitle.BackgroundTransparency = 1
KeySubTitle.Text = "Key System"
KeySubTitle.TextColor3 = Colors.TextGray
KeySubTitle.Font = Enum.Font.GothamMedium
KeySubTitle.TextSize = 13
KeySubTitle.TextXAlignment = Enum.TextXAlignment.Left

-- Close Button
local CloseBtn = Instance.new("TextButton", KeyGroup)
CloseBtn.Size = UDim2.new(0, 30, 0, 30)
CloseBtn.Position = UDim2.new(1, -35, 0, 10)
CloseBtn.BackgroundTransparency = 1
CloseBtn.Text = "✕"
CloseBtn.TextColor3 = Colors.TextGray
CloseBtn.TextSize = 18
CloseBtn.Font = Enum.Font.GothamBold
CloseBtn.MouseEnter:Connect(function() TweenService:Create(CloseBtn, TweenInfo.new(0.2), {TextColor3 = Color3.fromRGB(255, 80, 80)}):Play() end)
CloseBtn.MouseLeave:Connect(function() TweenService:Create(CloseBtn, TweenInfo.new(0.2), {TextColor3 = Colors.TextGray}):Play() end)
CloseBtn.MouseButton1Click:Connect(function() ScreenGui:Destroy() end)

-- Key Input Section
local KeyLabel = Instance.new("TextLabel", KeyGroup)
KeyLabel.Size = UDim2.new(0, 200, 0, 20)
KeyLabel.Position = UDim2.new(0, 20, 0, 75)
KeyLabel.BackgroundTransparency = 1
KeyLabel.Text = "Key"
KeyLabel.TextColor3 = Colors.TextGray
KeyLabel.Font = Enum.Font.GothamMedium
KeyLabel.TextSize = 13
KeyLabel.TextXAlignment = Enum.TextXAlignment.Left

local InputBg = Instance.new("Frame", KeyGroup)
InputBg.Size = UDim2.new(0, 230, 0, 35)
InputBg.Position = UDim2.new(0, 20, 0, 95)
InputBg.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
Instance.new("UICorner", InputBg).CornerRadius = UDim.new(0, 6)

local KeyBox = Instance.new("TextBox", InputBg)
KeyBox.Size = UDim2.new(1, -20, 1, 0)
KeyBox.Position = UDim2.new(0, 10, 0, 0)
KeyBox.BackgroundTransparency = 1
KeyBox.Text = ""
KeyBox.PlaceholderText = "Enter key here..."
KeyBox.TextColor3 = Colors.TextWhite
KeyBox.PlaceholderColor3 = Color3.fromRGB(100, 100, 100)
KeyBox.Font = Enum.Font.Gotham
KeyBox.TextSize = 14
KeyBox.TextXAlignment = Enum.TextXAlignment.Left
KeyBox.ClearTextOnFocus = false

-- Note Section
local NoteLabel = Instance.new("TextLabel", KeyGroup)
NoteLabel.Size = UDim2.new(0, 200, 0, 20)
NoteLabel.Position = UDim2.new(0, 270, 0, 75)
NoteLabel.BackgroundTransparency = 1
NoteLabel.Text = "Note"
NoteLabel.TextColor3 = Colors.TextGray
NoteLabel.Font = Enum.Font.GothamMedium
NoteLabel.TextSize = 13
NoteLabel.TextXAlignment = Enum.TextXAlignment.Left

local NoteSub = Instance.new("TextLabel", KeyGroup)
NoteSub.Size = UDim2.new(0, 200, 0, 20)
NoteSub.Position = UDim2.new(0, 270, 0, 95)
NoteSub.BackgroundTransparency = 1
NoteSub.Text = "Key is: leak888"
NoteSub.TextColor3 = Colors.TextWhite
NoteSub.Font = Enum.Font.GothamBold
NoteSub.TextSize = 14
NoteSub.TextXAlignment = Enum.TextXAlignment.Left

-- ลากหน้าต่าง Key
local keyDragging, keyDragInput, keyDragStart, keyStartPos
KeyGroup.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        keyDragging = true; keyDragStart = input.Position; keyStartPos = KeyGroup.Position
        input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then keyDragging = false end end)
    end
end)
KeyGroup.InputChanged:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then keyDragInput = input end end)
UserInputService.InputChanged:Connect(function(input)
    if input == keyDragInput and keyDragging then
        local delta = input.Position - keyDragStart
        KeyGroup.Position = UDim2.new(keyStartPos.X.Scale, keyStartPos.X.Offset + delta.X, keyStartPos.Y.Scale, keyStartPos.Y.Offset + delta.Y)
    end
end)

-- [ LOGIC: KEY CHECK & ANIMATIONS ]
-- 1. Animation Fade In ตอนรันโค้ด
TweenService:Create(KeyGroup, TweenInfo.new(0.6, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {GroupTransparency = 0}):Play()

-- 2. เช็ค Key ตอนกด Enter
KeyBox.FocusLost:Connect(function(enterPressed)
    if enterPressed then
        if KeyBox.Text == CorrectKey then
            -- ใส่ถูก: เฟดหายไป แล้วโหลด Main GUI
            KeyBox.TextColor3 = Color3.fromRGB(100, 255, 100)
            task.wait(0.2)
            
            local fadeOut = TweenService:Create(KeyGroup, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {GroupTransparency = 1})
            fadeOut:Play()
            fadeOut.Completed:Connect(function()
                KeyGroup:Destroy()
                loadMainGUI() -- เรียกหน้าหลักขึ้นมา
            end)
        else
            -- ใส่ผิด: ขึ้นเตือนสีแดงแล้วเคลียร์
            KeyBox.Text = "Invalid Key!"
            KeyBox.TextColor3 = Color3.fromRGB(255, 80, 80)
            task.wait(1)
            KeyBox.Text = ""
            KeyBox.TextColor3 = Colors.TextWhite
        end
    end
end)
