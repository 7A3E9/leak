-- Modern Button Creator
local function createRowButton(text, actionText)
    local Btn = Instance.new("TextButton")
    Btn.Parent = Content
    Btn.Size = UDim2.new(1, 0, 0, 38)
    Btn.BackgroundColor3 = Colors.ElementBg
    Btn.AutoButtonColor = false
    Btn.Text = ""; Btn.BackgroundTransparency = 1
    
    Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 6)
    local s = Instance.new("UIStroke", Btn)
    s.Color = Colors.Stroke; s.Transparency = 1
    
    local mt = Instance.new("TextLabel")
    mt.Parent = Btn
    mt.Size = UDim2.new(1, -90, 1, 0)
    mt.Position = UDim2.new(0, 12, 0, 0)
    mt.BackgroundTransparency = 1
    mt.Text = text
    mt.TextColor3 = Colors.TextWhite
    mt.Font = Enum.Font.GothamMedium
    mt.TextSize = 14
    mt.TextXAlignment = Enum.TextXAlignment.Left
    mt.TextTransparency = 1
    
    local af = Instance.new("Frame")
    af.Parent = Btn
    af.Size = UDim2.new(0, 70, 0, 24)
    af.Position = UDim2.new(1, -80, 0.5, -12)
    af.BackgroundColor3 = Colors.Background
    af.BackgroundTransparency = 1
    Instance.new("UICorner", af).CornerRadius = UDim.new(0, 4)
    
    local al = Instance.new("TextLabel")
    al.Parent = af
    al.Size = UDim2.new(1, 0, 1, 0)
    al.BackgroundTransparency = 1
    al.Text = actionText or "Execute"
    al.TextColor3 = Colors.TextGray
    al.Font = Enum.Font.Gotham
    al.TextSize = 12
    al.TextTransparency = 1
    
    Btn.MouseEnter:Connect(function()
        TweenService:Create(Btn, TweenInfo.new(0.2), {BackgroundColor3 = Colors.Hover}):Play()
        TweenService:Create(al, TweenInfo.new(0.2), {TextColor3 = Colors.TextWhite}):Play()
    end)
    Btn.MouseLeave:Connect(function()
        TweenService:Create(Btn, TweenInfo.new(0.2), {BackgroundColor3 = Colors.ElementBg}):Play()
        TweenService:Create(al, TweenInfo.new(0.2), {TextColor3 = Colors.TextGray}):Play()
    end)
    
    return Btn, mt, s, af, al
end

local Btn1, T1, S1, AF1, AL1 = createRowButton("💾  Leak Standard Script", "Save")
local Btn2, T2, S2, AF2, AL2 = createRowButton("🗺️  Leak Map (With Terrain)", "Load")

