-- Button Creator Function
local function createBtn(txt, subTxt)
    local B = Instance.new("TextButton")
    B.Size = UDim2.new(1, 0, 0, 45)
    B.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    B.Text = ""
    B.AutoButtonColor = false
    B.Parent = Content
    B.BackgroundTransparency = 1
    
    Instance.new("UICorner", B).CornerRadius = UDim.new(0, 6)
    local s = Instance.new("UIStroke", B)
    s.Color = Colors.Stroke
    s.Transparency = 1
    
    local t = Instance.new("TextLabel")
    t.Size = UDim2.new(1, -20, 1, 0)
    t.Position = UDim2.new(0, 10, 0, 0)
    t.BackgroundTransparency = 1
    t.Text = txt
    t.TextColor3 = Colors.Text
    t.Font = Enum.Font.GothamMedium
    t.TextSize = 14
    t.TextXAlignment = 0
    t.TextTransparency = 1
    t.Parent = B
    
    return B, t, s
end

local Btn1, T1, S1 = createBtn("💾  Leak Standard Script")
local Btn2, T2, S2 = createBtn("🗺️  Leak Map (With Terrain)")

-------------------------------------------------------------------------------
-- [ ANIMATION LOGIC ]
-------------------------------------------------------------------------------

-- 1. FADE IN KEY SYSTEM
local function FadeInKey()
    TweenService:Create(KeyFrame, TWEEN_INFO, {BackgroundTransparency = 0}):Play()
    TweenService:Create(KeyStroke, TWEEN_INFO, {Transparency = 0}):Play()
    TweenService:Create(KeyTitle, TWEEN_INFO, {TextTransparency = 0}):Play()
    TweenService:Create(KeySub, TWEEN_INFO, {TextTransparency = 0}):Play()
    TweenService:Create(KeyLabel, TWEEN_INFO, {TextTransparency = 0}):Play()
    TweenService:Create(TextBox, TWEEN_INFO, {BackgroundTransparency = 0, TextTransparency = 0}):Play()
    TweenService:Create(NoteTitle, TWEEN_INFO, {TextTransparency = 0}):Play()
    TweenService:Create(NoteText, TWEEN_INFO, {TextTransparency = 0}):Play()
end

-- 2. FADE OUT KEY SYSTEM
local function FadeOutKey()
    TweenService:Create(KeyFrame, TWEEN_INFO, {BackgroundTransparency = 1}):Play()
    TweenService:Create(KeyStroke, TWEEN_INFO, {Transparency = 1}):Play()
    TweenService:Create(KeyTitle, TWEEN_INFO, {TextTransparency = 1}):Play()
    TweenService:Create(KeySub, TWEEN_INFO, {TextTransparency = 1}):Play()
    TweenService:Create(KeyLabel, TWEEN_INFO, {TextTransparency = 1}):Play()
    TweenService:Create(TextBox, TWEEN_INFO, {BackgroundTransparency = 1, TextTransparency = 1}):Play()
    TweenService:Create(NoteTitle, TWEEN_INFO, {TextTransparency = 1}):Play()
    TweenService:Create(NoteText, TWEEN_INFO, {TextTransparency = 1}):Play()
    task.wait(0.5)
    KeyFrame.Visible = false
end

-- 3. FADE IN MAIN HUB
local function FadeInMain()
    MainFrame.Visible = true
    TweenService:Create(MainFrame, TWEEN_INFO, {BackgroundTransparency = 0}):Play()
    TweenService:Create(MainStroke, TWEEN_INFO, {Transparency = 0}):Play()
    TweenService:Create(Title, TWEEN_INFO, {TextTransparency = 0}):Play()
    
    TweenService:Create(Btn1, TWEEN_INFO, {BackgroundTransparency = 0}):Play()
    TweenService:Create(T1, TWEEN_INFO, {TextTransparency = 0}):Play()
    TweenService:Create(S1, TWEEN_INFO, {Transparency = 0}):Play()
    
    TweenService:Create(Btn2, TWEEN_INFO, {BackgroundTransparency = 0}):Play()
    TweenService:Create(T2, TWEEN_INFO, {TextTransparency = 0}):Play()
    TweenService:Create(S2, TWEEN_INFO, {Transparency = 0}):Play()
end

-------------------------------------------------------------------------------
-- [ CORE FUNCTIONALITY ]
-------------------------------------------------------------------------------

-- Check Key
TextBox:GetPropertyChangedSignal("Text"):Connect(function()
    if TextBox.Text == CORRECT_KEY then
        TextBox.TextEditable = false
        TextBox.TextColor3 = Color3.fromRGB(100, 255, 100) -- Green
        task.wait(0.3)
        FadeOutKey()
        task.wait(0.2)
        FadeInMain()
    end
end)

-- Dragging Logic
local function makeDraggable(f)
    local dragStart, startPos, dragging
    f.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = i.Position
            startPos = f.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = i.Position - dragStart
            f.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    f.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
end

makeDraggable(KeyFrame)
makeDraggable(MainFrame)

-- Start Application
FadeInKey()

-- [ BUTTON COMMANDS ]
Btn1.MouseButton1Click:Connect(function()
    if saveinstance then saveinstance() else print("Not supported") end
end)

Btn2.MouseButton1Click:Connect(function()
    loadstring(game:HttpGet("https://raw.githubusercontent.com/verysigmapro/UniversalSynSaveInstance-With-Save-Terrain/refs/heads/main/saveinstance_rewrite.luau"))()
end)
