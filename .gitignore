-- [ DRAGGABLE LOGIC ]
local dragging, dragInput, dragStart, startPos
MainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

MainFrame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

-- [ BUTTON LOGIC ]

-- Function: Set Status
local function setStatus(text, color)
    StatusLabel.Text = text
    StatusLabel.TextColor3 = color or Color3.fromRGB(150, 150, 150)
end

-- Button 1: Standard
Btn1.MouseButton1Click:Connect(function()
    setStatus("Saving Script...", Color3.fromRGB(255, 255, 150))
    task.wait(0.5)
    
    if not saveinstance then
        setStatus("Error: Executor unsupported", Color3.fromRGB(255, 80, 80))
        return
    end
    
    local success, err = pcall(function()
        saveinstance()
    end)
    
    if success then
        setStatus("Success! Check workspace folder.", Color3.fromRGB(100, 255, 100))
    else
        setStatus("Error: " .. tostring(err):sub(1, 20), Color3.fromRGB(255, 80, 80))
    end
end)

-- Button 2: Terrain (Loadstring)
Btn2.MouseButton1Click:Connect(function()
    setStatus("Downloading Terrain Saver...", Color3.fromRGB(255, 255, 150))
    task.wait(0.5)
    
    local success, err = pcall(function()
        -- โค้ดที่ผู้ใช้ให้มา
        local synsaveinstance = loadstring(game:HttpGet("https://raw.githubusercontent.com/verysigmapro/UniversalSynSaveInstance-With-Save-Terrain/refs/heads/main/saveinstance_rewrite.luau", true), "saveinstance")();
        local SaveinstanceOptions = {usekonstantdecompiler=false} --set to true if u dont have a decompiler
        synsaveinstance(SaveinstanceOptions);
    end)
    
    if success then
        setStatus("Success! Map saved.", Color3.fromRGB(100, 255, 100))
    else
        setStatus("Error: " .. tostring(err):sub(1, 20), Color3.fromRGB(255, 80, 80))
    end
end)
